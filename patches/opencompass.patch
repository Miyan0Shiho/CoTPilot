diff --git a/opencompass/utils/text_postprocessors.py b/opencompass/utils/text_postprocessors.py
index 8eed2647..450d8997 100644
--- a/opencompass/utils/text_postprocessors.py
+++ b/opencompass/utils/text_postprocessors.py
@@ -284,3 +284,19 @@ def extract_non_reasoning_content(
                                  re.DOTALL)
     non_reasoning_content = reasoning_regex.sub('', text).strip()
     return non_reasoning_content
+
+
+@TEXT_POSTPROCESSORS.register_module('gsm8k_dataset')
+def gsm8k_dataset_postprocess(text: str) -> str:
+    if '#### ' in text:
+        return text.split('#### ')[1].replace(',', '')
+    return text.replace(',', '')
+
+
+@TEXT_POSTPROCESSORS.register_module('gsm8k')
+def gsm8k_postprocess(text: str) -> str:
+    text = text.split('Question:')[0]
+    numbers = re.findall(r'\-?\d+\.\d+|\-?\d+', text)
+    if not numbers:
+        return 'NULL'
+    return numbers[-1]
